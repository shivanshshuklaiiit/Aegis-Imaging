IRONLABS_API_KEY=your_ironlabs_key_here
IRONLABS_BASE_URL=https://api.ironlabs.ai/v1

# Model overrides (optional — defaults match Architecture PRD §8)
IRONLABS_MODEL_CHEAP=llama-3.1-8b-instruct
IRONLABS_MODEL_MID=gpt-4o-mini
IRONLABS_MODEL_TOP=claude-sonnet-4-5

HF_TOKEN=your_huggingface_token_here

DATABASE_URL=data/aegis.db
DEMO_MODE=false

# Webhook targets (P4 owns these endpoints)
MOCK_EHR_URL=http://localhost:8000/mock-ehr
MOCK_CLAIMS_URL=http://localhost:8000/mock-claims
